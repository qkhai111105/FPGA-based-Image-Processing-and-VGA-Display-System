module rgb565_to_gray (
    input  wire        clk,
    input  wire        rst_n,
    input  wire [15:0] rgb565_in,
    input  wire        valid_in,   // Pulses high when input data is valid
    
    output reg  [7:0]  gray_out,   // 8-bit grayscale output
    output reg         valid_out   // Pulses high when output data is valid
);

    // Pipeline Data Registers
    reg [7:0]  r_8, g_8, b_8;
    reg [15:0] r_mult, g_mult, b_mult;
    reg [16:0] sum;
    
    // Valid Signal Pipeline
    reg valid_d1, valid_d2;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            // Reset state
            r_8 <= 8'd0; g_8 <= 8'd0; b_8 <= 8'd0;
            r_mult <= 16'd0; g_mult <= 16'd0; b_mult <= 16'd0;
            sum <= 17'd0;
            gray_out <= 8'd0;
            valid_d1 <= 1'b0; valid_d2 <= 1'b0; valid_out <= 1'b0;
        end else begin
            // ----------------------------------------------------
            // STAGE 1: Extract and Normalize to 8-bit
            // ----------------------------------------------------
            // Red: 5 bits -> 8 bits
            r_8 <= {rgb565_in[15:11], rgb565_in[13:11]}; 
            // Green: 6 bits -> 8 bits
            g_8 <= {rgb565_in[10:5],  rgb565_in[9:8]};   
            // Blue: 5 bits -> 8 bits
            b_8 <= {rgb565_in[4:0],   rgb565_in[2:0]};   
            
            valid_d1 <= valid_in;

            // ----------------------------------------------------
            // STAGE 2: Constant Multiplication
            // ----------------------------------------------------
            // In an FPGA, synthesis tools will automatically map 
            // these to DSP slices or optimize them into shift-adds.
            r_mult <= r_8 * 8'd77;
            g_mult <= g_8 * 8'd150;
            b_mult <= b_8 * 8'd29;
            
            valid_d2 <= valid_d1;

            // ----------------------------------------------------
            // STAGE 3: Addition and Bit-Shift (Division by 256)
            // ----------------------------------------------------
            sum <= r_mult + g_mult + b_mult;
            
            // Shifting right by 8 is equivalent to taking bits [15:8].
            // We use the sum directly in the same clock cycle to save a register,
            // or register the final output.
            gray_out <= sum[15:8]; 
            
            valid_out <= valid_d2;
        end
    end

endmodule