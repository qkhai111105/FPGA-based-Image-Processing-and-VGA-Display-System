module dm9000a_controller (

	// arbiter interface
	input wire clk_50,
	input wire clk_25,
	input wire rst_n,
	input wire [15:0] data_i,
	output wire [15:0] data_o,
	input wire [7:0] addr,
	input wire write_n,
	input wire read_n,
	output reg data_valid,
	output reg busy
	
	// dm9000a interface
	inout [15:0] enet_data,
	output wire enet_clk,
	output reg enet_cmd,
	output reg enet_cs_n,
	input enet_int,
	output reg enet_rd_n,
	output reg enet_wr_n,
	output wire enet_rst_n
	
);
	
	reg [15:0] enet_data_reg;
	reg drive_data_bus;
	
	assign enet_data = (drive_data_bus == 1'b1 && enet_cs_n == 1'b0)? enet_data_reg : 16'hzzzz;
	assign enet_rst_n = rst_n;
	assign enet_clk = clk_25;
	
	always @(posedge clk_50 or negedge rst_n) begin 
		if (rst_n == 1'b0) begin
			enet_clk <= 0;
			enet_cmd <= 0;
			enet_cs_n <= 1;
			enet_rd_n <= 1;
			enet_wr_n <= 1;
			rdready <= 0;
			valid <= 0;
			busy <= 0;
			drive_data_bus <= 0;
		end else begin 
		
		end
	
	end

endmodule

